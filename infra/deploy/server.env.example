DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PORT=22
DEPLOY_PATH=/var/www/warehouse-platform

NODE_ENV=production
API_HOST=127.0.0.1
API_PORT=8044
JWT_ACCESS_SECRET=replace-me-with-long-random-production-secret

# Production data plane.
DATABASE_URL=postgres://warehouse:change-me@127.0.0.1:5432/warehouse_platform
REDIS_URL=redis://127.0.0.1:6379
FILE_STORAGE_DRIVER=s3
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=ru-central1
S3_BUCKET=warehouse-platform
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true
POSTGRES_BACKUP_DIR=/var/backups/warehouse-platform/postgres
POSTGRES_BACKUP_KEEP=14

# Tenant OTP delivery. Choose one or several channels: telegram,vk,whatsapp.
OTP_DELIVERY_CHANNELS=telegram
TENANT_OTP_TTL_MS=300000
TENANT_OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_TTL_MS=600000
MFA_CHALLENGE_TTL_MS=300000
TOTP_ISSUER=sklad kontur

# Telegram: user must first open the bot. Map tenant phones/user ids to Telegram chat ids.
TELEGRAM_BOT_TOKEN=
TENANT_TELEGRAM_BOT_URL=https://t.me/warehousecontourbot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_OTP_CHAT_IDS_JSON={"+79990000001":"123456789"}

# VK: user must allow messages from the community. Map tenant phones/user ids to VK user ids.
VK_GROUP_TOKEN=
VK_API_VERSION=5.199
TENANT_VK_BOT_URL=https://vk.com/club239116063
VK_CONFIRMATION_CODE=
VK_WEBHOOK_SECRET=
VK_OTP_USER_IDS_JSON={"+79990000001":"123456789"}

# WhatsApp Business Cloud API: requires approved template with the OTP as a body variable.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TENANT_WHATSAPP_BOT_URL=
WHATSAPP_OTP_TEMPLATE_NAME=
WHATSAPP_OTP_TEMPLATE_LANGUAGE=ru

# Email and in-app notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=sklad kontur <noreply@skladkontur.ru>
NOTIFICATION_CHANNELS=in_app,email

# Native release branding. Override only if store package ids are already reserved.
WAREHOUSE_ANDROID_APP_ID=ru.skladkontur.app
WAREHOUSE_ANDROID_APP_NAME=sklad kontur
